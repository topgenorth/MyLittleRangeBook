<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:SharedControls.Controls;assembly=SharedControls"
             xmlns:services="clr-namespace:SharedControls.Services;assembly=SharedControls"
             xmlns:converters="clr-namespace:SharedControls.Converters;assembly=SharedControls"
             xmlns:viewModels="clr-namespace:MyLittleRangeBook.GUI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             services:DialogManager.Register="{Binding}"
             Width="{Binding $parent[controls:OverlayDialog].Bounds.Width, Converter={x:Static converters:MathConverter.Multiply}, ConverterParameter=0.7}"
             MaxWidth="700"
             x:Name="Root"
             x:Class="MyLittleRangeBook.GUI.Views.EditSimpleRangeEventView"
             x:DataType="viewModels:EditSimpleRangeEventViewModel">

    <!--             Design.DataContext="{x:Static viewModels:_DesignData.EditSimpleRangeEventViewModel}"
-->
    <Grid Margin="10"
          RowDefinitions="*, Auto"
          RowSpacing="10">
        <ScrollViewer DataContext="{Binding Item}">
            <StackPanel Grid.IsSharedSizeScope="True" Spacing="5">

                <!--  Firearm  -->
                <controls:LabeledControl Header="Firearm">
                    <TextBox x:Name="FirearmTextBox"
                             HorizontalAlignment="Left"
                             Text="{Binding FirearmName}"
                             PlaceholderText="The name of the firearm" />
                </controls:LabeledControl>

                <!--  Rounds   -->
                <controls:LabeledControl Header="Rounds">
                    <NumericUpDown Value="{Binding RoundsFired}"
                                   Minimum="0"
                                   Maximum="10000"
                                   Increment="1"
                                   FormatString="0"
                                   HorizontalAlignment="Left" />
                </controls:LabeledControl>

                <!--  Event Date  -->
                <controls:LabeledControl Header="Event Date">
                    <CalendarDatePicker SelectedDate="{Binding EventDate}"
                                        HorizontalAlignment="Left" />
                </controls:LabeledControl>


                <!--  Range   -->
                <controls:LabeledControl Header="Range">
                    <TextBox x:Name="RangeTextBox" Text="{Binding RangeName}" PlaceholderText="The name of the range" />
                </controls:LabeledControl>


                <!--  Ammo  -->
                <controls:LabeledControl Header="Ammo">
                    <TextBox Text="{Binding AmmoDescription}"
                             AcceptsReturn="True"
                             MaxHeight="200" />
                </controls:LabeledControl>


                <!--  Notes  -->
                <controls:LabeledControl Header="Notes">
                    <TextBox Text="{Binding Notes}"
                             AcceptsReturn="True"
                             MaxHeight="400" />
                </controls:LabeledControl>

                <!-- Some Infos -->
                <StackPanel VerticalAlignment="Bottom"
                            HorizontalAlignment="Stretch"
                            Orientation="Horizontal">
                    <controls:LabeledControl Header="Id" Classes="ExtraInfo"
                                             Content="{Binding Id, TargetNullValue='Not yet completed'}"
                                             VerticalContentAlignment="Center" />
                    <controls:LabeledControl Header="Last Updated" Classes="ExtraInfo"
                                             Content="{Binding Modified, StringFormat='{}{0:g}', TargetNullValue='Not yet completed'}"
                                             VerticalContentAlignment="Center" />
                    <controls:LabeledControl Classes="ExtraInfo"
                                             Header="Created Date" Content="{Binding Created, StringFormat='{}{0:g}', TargetNullValue='Not yet completed'}"
                                             VerticalContentAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <WrapPanel Grid.Row="1"
                   HorizontalAlignment="Right"
                   ItemSpacing="5"
                   Orientation="Horizontal">
            <Button x:Name="CancelButton" Command="{Binding CancelCommand}" Content="Cancel" />
            <Button x:Name="SaveButton" Command="{Binding SaveCommand}" Content="Save" />
        </WrapPanel>
    </Grid>
</UserControl>